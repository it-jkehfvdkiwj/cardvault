# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# Environment & secrets
.env
*.env

# Database
*.db
*.db-shm
*.db-wal

# Uploads (user files, not tracked)
backend/uploads/

# Tesseract language data. Ship eng + deu so the deployed container can OCR
# (the dir is otherwise empty in the image and every OCR call fails silently).
# osd is large and unused, so keep it out.
backend/tessdata/*.traineddata
!backend/tessdata/eng.traineddata
!backend/tessdata/deu.traineddata

# Frontend build output
frontend/dist/
frontend/node_modules/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
