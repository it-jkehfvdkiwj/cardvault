POKEMON_TCG_API_KEY=your_api_key_here
DATABASE_URL=sqlite:///./cardvault.db
UPLOAD_DIR=uploads
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to sign login tokens (JWT). CHANGE THIS to a long random string in
# production — anyone who knows it can forge logins. Generate one e.g. with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-secret-change-me-0123456789-abcdefghij
JWT_EXPIRE_DAYS=30

# Comma-separated emails that are auto-promoted to admin on login/register.
# Set this to YOUR email to unlock the Admin panel, then log in again.
ADMIN_EMAILS=quirin06@mail.de

# ── Billing / subscriptions ───────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173      # used for Stripe redirect URLs
ALLOW_DEMO_BILLING=true                  # set to false once Stripe is live
# Stripe (optional — fill to enable real card payments):
#   pip install stripe
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ── Email (for password-reset mails) ──────────────────────────────────────────
# Without these, reset links are printed to the server console (dev convenience).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# Cardmarket API (optional – get credentials at developers.cardmarket.com)
# Without these, Cardmarket search and EUR prices from the CM API are disabled.
# EUR trend prices embedded in TCG API responses still work without these keys.
CM_APP_TOKEN=
CM_APP_SECRET=
CM_ACCESS_TOKEN=
CM_ACCESS_SECRET=

# ── OCR / scanning ────────────────────────────────────────────────────────────
# Path to the tesseract binary (only needed if not on the Windows default path).
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Folder containing eng.traineddata + deu.traineddata (bundled in backend/tessdata).
# TESSDATA_DIR=
# Languages used for card-name OCR (German first so umlauts read correctly).
# OCR_NAME_LANGS=deu+eng

# ── eBay CSV export defaults (no eBay account needed for CSV) ──────────────────
EBAY_SITE=DE                       # DE/AT/UK/US/FR/IT/ES
EBAY_CATEGORY=183454               # Pokémon Einzelkarten — VERIFY for your marketplace!
EBAY_FORMAT=FixedPrice
EBAY_DURATION=GTC
EBAY_LOCATION=Deutschland
EBAY_SHIPPING_SERVICE=DE_DeutschePostBrief
EBAY_SHIPPING_COST=1.80
EBAY_PRICE_MULTIPLIER=1.0          # 1.0 = Cardmarket trend price
EBAY_MIN_PRICE=0.99
EBAY_ROUND_99=true
USD_EUR_RATE=0.92                  # fallback when only a USD price is known

# ── eBay Sell API (OPTIONAL — only for direct live listing, see ebay_api_service) ─
# EBAY_ENV=production               # or "sandbox"
# EBAY_MARKETPLACE_ID=EBAY_DE
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_REFRESH_TOKEN=
